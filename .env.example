# =========================================================
# Copy this file to .env and fill in real values.
# .env is in .gitignore and must never be committed.
# =========================================================

# --- LiteLLM proxy (preferred) ---
LITELLM_API_BASE=https://your-litellm-proxy.example.com
LITELLM_API_KEY=sk-your-litellm-virtual-key
LITELLM_MODEL=azure_ai/gpt-oss-120b

# --- Database ---
# Local default is SQLite. Set to a Postgres URL in production.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./triage.db

# --- Frontend ---
# Base URL the React app calls. Point to your local or deployed API.
VITE_API_BASE_URL=http://127.0.0.1:8000

# --- CORS (optional) ---
# Comma-separated origins, or use CORS_ALLOW_ORIGIN_REGEX for patterns.
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ALLOW_ORIGIN_REGEX=^https://.*\.onrender\.com$

# --- Optional direct Azure AI access (bypasses proxy) ---
# AZURE_API_BASE=
# AZURE_API_KEY=
